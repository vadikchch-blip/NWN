# Cloudflare R2 Configuration
# Get these values from your Cloudflare dashboard:
# Dashboard > R2 > Manage R2 API Tokens

# Your Cloudflare Account ID (found in the URL when logged into dashboard)
R2_ACCOUNT_ID=your_account_id_here

# R2 API Token - Access Key ID
R2_ACCESS_KEY_ID=your_access_key_id_here

# R2 API Token - Secret Access Key
R2_SECRET_ACCESS_KEY=your_secret_access_key_here

# R2 Bucket Name (must be private bucket)
R2_BUCKET_NAME=podcasts

# Server Configuration
PORT=3000

# URL expiration time in seconds (5-10 minutes recommended)
# 300 = 5 minutes, 600 = 10 minutes
URL_EXPIRATION_SECONDS=600

# Allowed origins for CORS (comma-separated)
# Leave empty or set to * for development
# In production, set to your domain: https://yourdomain.com
ALLOWED_ORIGINS=

# ── Supreme First Access ──
# PostgreSQL (Railway)
DATABASE_URL=postgresql://user:pass@host:port/dbname
DATABASE_PUBLIC_URL=postgresql://user:pass@host:port/dbname

# Public base URL for First Access photos (Cloudflare R2 public URL, no trailing slash)
# e.g. https://your-bucket.r2.dev/first-access/supreme-2026-03
R2_PUBLIC_BASE_URL=

# Max active reservations per invite (default 2)
MAX_ACTIVE_RESERVATIONS_PER_INVITE=2

# Reservation TTL in hours (default 24)
RESERVATION_TTL_HOURS=24
